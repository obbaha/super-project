    branches:
      - main  # يعمل عند الدفع لفرع main

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Deploy via SSH
        uses: appleboy/ssh-action@master
        with:
          host: 82.198.228.57
          username: u162093132
          key: ${{ secrets.SSH_PRIVATE_KEY }} # سنضيفه في إعدادات GitHub
          port: 65002
          script: |
            cd ~/domains/syriashop0.com/laravel_code
            git pull origin main
            php artisan config:cache
